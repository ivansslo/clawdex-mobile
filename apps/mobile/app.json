{
  "expo": {
    "name": "Clawdex Mobile",
    "slug": "clawdex-mobile",
    "scheme": "clawdex",
    "version": "5.2.1",
    "userInterfaceStyle": "automatic",
    "orientation": "portrait",
    "icon": "./assets/brand/app-icon.png",
    "splash": {
      "image": "./assets/brand/splash-icon-white.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "appleTeamId": "4NWUS8362L",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsArbitraryLoadsInWebContent": true,
          "NSAllowsLocalNetworking": true
        }
      },
      "bundleIdentifier": "com.mohitpatil973.clawdexmobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.mohitpatil973.clawdexmobile"
    },
    "web": {
      "favicon": "./assets/brand/favicon.png"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "./plugins/withAndroidCleartextTraffic",
      [
        "expo-camera",
        {
          "cameraPermission": "Clawdex uses the camera to scan bridge pairing QR codes and capture photos you want to attach to a chat."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Clawdex uses your photo library so you can choose an image from your phone and attach it to a chat prompt or workflow sent to your own host bridge.",
          "cameraPermission": "Clawdex uses the camera to scan bridge pairing QR codes and capture photos you want to attach to a chat.",
          "microphonePermission": "Clawdex uses the microphone to record a short voice message that is transcribed into your chat input."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Clawdex uses the microphone to record a short voice message that is transcribed into your chat input.",
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "07937be8-e2f7-4731-8ea4-cefae952df79"
      }
    }
  }
}
