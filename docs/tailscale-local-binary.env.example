# Copy ke .env.secure atau export di terminal sebelum start.
# File .env.secure akan dibaca otomatis oleh scripts/start-tailscale-local-binary.sh

# Ganti dengan token panjang/rahasia kamu.
BRIDGE_AUTH_TOKEN=clawdex_change_me_to_a_long_random_secret

# Port bridge utama dan preview localhost.
BRIDGE_PORT=8787
BRIDGE_PREVIEW_PORT=8788

# Workdir yang akan dipakai Codex/OpenCode/Cursor.
# Default: root repo clawdex-mobile.
# BRIDGE_WORKDIR=/Users/you/project

# Engine default: codex. Pilihan: codex, opencode, cursor
BRIDGE_ACTIVE_ENGINE=codex
BRIDGE_ENABLED_ENGINES=codex

# Path binary CLI jika tidak ada di PATH.
# CODEX_CLI_BIN=codex
# OPENCODE_CLI_BIN=opencode
# CURSOR_APP_SERVER_BIN=cursor-app-server

# Keamanan terminal exec.
BRIDGE_DISABLE_TERMINAL_EXEC=false
BRIDGE_TERMINAL_ALLOWED_COMMANDS=pwd,ls,cat,git
BRIDGE_ALLOW_QUERY_TOKEN_AUTH=false
BRIDGE_SHOW_PAIRING_QR=true
